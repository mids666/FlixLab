rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email']) && data.email is string;
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['name']) && data.name is string;
    }

    function isValidWatchlistItem(data) {
      return data.keys().hasAll(['tmdbId', 'type']) &&
             data.tmdbId is string && data.type is string;
    }

    function isValidRecentlyWatchedItem(data) {
      return data.keys().hasAll(['tmdbId', 'type', 'watchedAt']) &&
             data.tmdbId is string && data.type is string && data.watchedAt is string;
    }

    // ===============================================================
    // Collection Paths
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);

      match /profiles/{profileId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidProfile(request.resource.data);
        allow delete: if isOwner(userId);

        match /watchlist/{itemId} {
          allow read: if isOwner(userId);
          allow create, update: if isOwner(userId) && isValidWatchlistItem(request.resource.data);
          allow delete: if isOwner(userId);
        }

        match /recentlyWatched/{itemId} {
          allow read: if isOwner(userId);
          allow create, update: if isOwner(userId) && isValidRecentlyWatchedItem(request.resource.data);
          allow delete: if isOwner(userId);
        }
      }
    }
  }
}
